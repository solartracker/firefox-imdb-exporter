{
  "manifest_version": 2,
  "name": "ViewSource JPG Saver",
  "version": "1.0",
  "description": "Downloads og:image JPG without viewing page source.",
  "permissions": [
    "downloads",
    "activeTab"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Save og:image JPG"
  }
}

