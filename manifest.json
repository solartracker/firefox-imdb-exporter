// about:debugging#/runtime/this-firefox

{
  "manifest_version": 3,
  "name": "IMDb - MiniDLNA Exporter",
  "version": "3.0",
  "description": "Creates MiniDLNA-compatible NFO and folder.jpg from IMDb pages.",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Export IMDb to MiniDLNA"
  }
}

